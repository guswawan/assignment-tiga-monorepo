{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env tsx watch src/index.ts",
    "worker:dev": "pnpm with-env tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:deploy": "pnpm with-env prisma migrate deploy",
    "db:generate": "pnpm with-env prisma generate",
    "db:studio": "pnpm with-env prisma studio",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@anvia/core": "^0.12.4",
    "@anvia/openai": "^0.3.16",
    "@anvia/server": "^0.5.1",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.79.3",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
